# inferia-worker configuration.
# Copy to .env, fill in the values, then `docker compose up -d`.

# Where the InferiaLLM control plane is reachable from this host.
# Use https in production; http is fine for local dev.
#
# When the control plane runs in a docker compose on the SAME host, attach
# the worker to its network (handled below via inferia-cp) and use the
# control plane's container hostname here — e.g. http://inferia-app:8000
# — not http://localhost:8000 (which resolves inside the worker container
# and won't reach the control plane).
CONTROL_PLANE_URL=https://control.example.com

# One-time bootstrap token obtained from the InferiaLLM admin UI.
# After first registration the worker mints a long-lived JWT and the
# bootstrap token can be rotated/removed.
BOOTSTRAP_TOKEN=replace-me

# A unique node name within the pool. Letters, digits, dots, dashes,
# underscores; max 255 chars; cannot contain '..'.
NODE_NAME=gpu-node-1

# The compute pool this node joins (uuid).
POOL_ID=00000000-0000-0000-0000-000000000000

# The URL the control plane will use to reach this worker's inference port.
# Must be a URL the control plane can dial — public IP / DNS, or a private
# address if the control plane is in the same network.
#
# When the control plane runs in a sibling compose on the same docker
# network, use the worker's compose service hostname here — e.g.
# http://inferia-worker:8080 — not http://localhost:8080 (which only
# resolves to the control plane's own container, not yours).
WORKER_ADVERTISE_URL=https://gpu-node-1.example.com:8080

# Shared secret that the control plane sends as `Authorization: Bearer ...`
# on every inference request to this worker. The same value must be set on
# the control plane as WORKER_INFERENCE_TOKEN. ≥16 bytes, ≤4096 bytes.
INFERENCE_TOKEN=replace-with-a-long-random-string

# --- Optional overrides (sensible defaults applied otherwise) -----------------

# Worker's Fiber bind address.
# WORKER_LISTEN_ADDR=0.0.0.0:8080

# Host port published by docker-compose.
# INFERENCE_PORT=8080

# Image tag.
# INFERIA_WORKER_IMAGE=ghcr.io/inferia/inferia-worker:v0.1.0

# debug | info | warn | error
# LOG_LEVEL=info

# Per-deployment defaults (timeouts in seconds).
# PULL_TIMEOUT_SECONDS=600
# READINESS_TIMEOUT_SECONDS=180

# Heartbeat cadence (seconds). The control plane marks a worker unreachable
# after 3 missed heartbeats.
# HEARTBEAT_INTERVAL_SECONDS=5

# Docker network on which the worker places model containers.
# MODELS_NETWORK=inferia-models

# --- GPU detection overrides --------------------------------------------------
#
# The worker auto-detects GPUs in this order:
#   1. `nvidia-smi --query-gpu=...` — gives accurate model names + VRAM.
#      Only works if the worker image ships nvidia-smi (the default
#      distroless image does NOT).
#   2. /dev/nvidia[0-9]+ device files — counted when nvidia-smi is missing.
#      Always works in distroless images when GPU passthrough is configured
#      in docker-compose. Cannot recover the real model name (reports
#      "NVIDIA") or VRAM.
#
# Override the detected values for unusual setups (e.g. passing only a
# subset of host GPUs through, or running on a host where the device
# files exist but the GPUs shouldn't be exposed).
#
# ALLOCATABLE_GPU_OVERRIDE — integer GPU count. Forces the advertised
#   gpu_total regardless of detection. Set to 0 to mark this node CPU-only
#   even when GPUs are physically passed through.
# ALLOCATABLE_GPU_MODELS_OVERRIDE — pipe-joined list of GPU model names
#   (e.g. "NVIDIA A100|NVIDIA A100"). Useful when /dev fallback reports
#   the generic "NVIDIA" but you want the scheduler to filter on real
#   models.
#
# ALLOCATABLE_GPU_OVERRIDE=1
# ALLOCATABLE_GPU_MODELS_OVERRIDE=NVIDIA
